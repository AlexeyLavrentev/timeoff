# Jira-TimeOff worker settings for docker-compose.yml
# Copy to .env and replace placeholder values.

TIMEOFF_TOKEN=replace_me

JIRA_BASE_URL=https://jira.example.local
JIRA_USER=svc-timeoff-reassign
JIRA_TOKEN=replace_me

JIRA_ASSIGN_FIELD=name
JIRA_EXTRA_JQL=
AUTO_MAP_BY_EMAIL=true

TIMEOFF_LEAVE_STATUSES=Approved
TIMEOFF_DATE=

# Start in dry-run mode first
DRY_RUN=true

MAPPING_REPORT_FILE=/app/integrations/jira-timeoff-worker/reports/mapping-report.json
# Optional guardrail. If not_found in mapping summary exceeds this number,
# worker exits with error.
MAPPING_NOT_FOUND_THRESHOLD=
HTTP_TIMEOUT_MS=20000
JIRA_SEARCH_PAGE_SIZE=100
WORKER_INTERVAL_SECONDS=600
