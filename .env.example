# Docker Compose example environment
# Copy to .env and adjust values if needed.

COMPOSE_PROJECT_NAME=timeoff
APP_PORT=3000

DB_DIALECT=mysql
DB_HOST=db
DB_PORT=3306
DB_NAME=timeoff
DB_USER=timeoff
DB_PASSWORD=timeoff_password
DB_LOGGING=false
RUN_DB_MIGRATIONS=false

MYSQL_DATABASE=timeoff
MYSQL_USER=timeoff
MYSQL_PASSWORD=timeoff_password
MYSQL_ROOT_PASSWORD=root_password
