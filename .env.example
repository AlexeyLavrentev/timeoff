SESSION_SECRET=replace-with-a-long-random-session-secret
CRYPTO_SECRET=replace-with-a-long-random-crypto-secret
TRUST_PROXY=0
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_MAX_AGE_MS=43200000

DB_DIALECT=mysql
DB_HOST=db
DB_PORT=3306
DB_NAME=timeoff
DB_USER=timeoff
DB_PASSWORD=timeoff_password
DB_LOGGING=false

MYSQL_DATABASE=timeoff
MYSQL_USER=timeoff
MYSQL_PASSWORD=timeoff_password
MYSQL_ROOT_PASSWORD=root_password

RUN_DB_MIGRATIONS=true
APP_PORT=3000

# Premium module delivery
TIMEOFF_PREMIUM_MODULE_HOST_PATH=../timeoff-premium
TIMEOFF_PREMIUM_MODULE=
TIMEOFF_PREMIUM_MODULE_REQUIRED=false

# Development-only premium switches. They are ignored in production/staging.
# Use them only together with the premium development module.
FEATURE_TIME_BALANCE=false
FEATURE_VACATION_PLANNING=false

# Production commercial mode requires both values and accepts RSA-SHA256 only.
TIMEOFF_LICENSE=
TIMEOFF_LICENSE_PUBLIC_KEY=
