#!/usr/bin/env node

var debug = require('debug')('vacation-tracker');
var app   = require('../app');
var leaveReminderScheduler = require('../lib/scheduler/leave_start_reminders');

var cluster = require('cluster');

if (cluster.isMaster ) {

  cluster.on('exit', function(worker, code){
    if(code != 0 && !worker.suicide) {
      console.log('>>>>>> Worker crashed. Starting a new worker');
      cluster.fork();
    }
  });

  [1,2].forEach(function(){cluster.fork()});

} else {
  app.set('port', process.env.PORT || 3000);

  app.get('db_model').connect()
    .then(function () {
      leaveReminderScheduler.startLeaveReminderScheduler({
        models : app.get('db_model'),
      });

      var server = app.listen(app.get('port'), function() {
        console.log('Started to listen on port ' + server.address().port);
      });
    })
    .catch(function(error) {
      console.error(error && error.stack || error);
      process.exit(1);
    });

}
