#!/usr/bin/env node

var debug = require('debug')('vacation-tracker');
var app   = require('../app');
var edition = require('../lib/edition');
var runtimeShutdown = require('../lib/runtime_shutdown');
var structuredLogger = require('../lib/middleware/request_logger');

var cluster = require('cluster');

if (cluster.isMaster ) {

  cluster.on('exit', function(worker, code){
    if(code != 0 && !worker.suicide) {
      structuredLogger.warn('cluster_worker_restarting', {workerId: worker.id, exitCode: code});
      cluster.fork();
    }
  });

  [1,2].forEach(function(){cluster.fork()});

} else {
  app.set('port', process.env.PORT || 3000);

  app.get('db_model').connect()
    .then(function () {
      edition.startSchedulers({
        app    : app,
        models : app.get('db_model'),
      });

      var server = app.listen(app.get('port'), function() {
        structuredLogger.info('server_listening', {port: server.address().port});
      });
      runtimeShutdown.installProcessHandlers({
        server: server,
        db: app.get('db_model').sequelize,
        exit: function(code) { process.exit(code); },
      });
    })
    .catch(function(error) {
      structuredLogger.error('startup_failed', {error: error});
      process.exit(1);
    });

}
