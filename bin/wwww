#!/usr/bin/env node

var debug = require('debug')('vacation-tracker');
var app   = require('../app');
var edition = require('../lib/edition');
var runtimeShutdown = require('../lib/runtime_shutdown');
var serverListener = require('../lib/server_listener');

app.set('port', process.env.PORT || 3000);
app.set('host', process.env.HOST || undefined);

app.get('db_model').connect()
  .then(function () {
    return serverListener.listen({
      app: app,
      port: app.get('port'),
      host: app.get('host'),
    });
  })
  .then(function (server) {
    edition.startSchedulers({
      app    : app,
      models : app.get('db_model'),
    });

    debug('Express server listening on port ' + server.address().port);
    runtimeShutdown.installProcessHandlers({
      server: server,
      db: app.get('db_model').sequelize,
      exit: function(code) { process.exit(code); },
    });
    if (typeof process.send === 'function') {
      process.send({type: 'test-server-ready'});
    }
  })
  .catch(function(error) {
    require('../lib/middleware/request_logger').error('startup_failed', {error: error});
    process.exit(1);
  });
