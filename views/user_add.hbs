
{{> header }}

<a class="sr-only sr-only-focusable" href="#main-content">{{t "nav.skipToMainContent"}}</a>

<main id="main-content" tabindex="-1">

<h1>{{t "userAdd.title"}}</h1>

<div class="row admin-page-header">
  <div class="col-sm-7 lead">{{t "userAdd.subtitle"}}</div>
  <div class="col-sm-5 admin-page-actions">
    <a class="btn btn-default" href="/users/import/" id="import_users_btn">{{t "users.importEmployees"}} <i class="fa fa-chevron-right" aria-hidden="true"></i></a>
  </div>
</div>

{{> show_flash_messages }}

<div class="content-spacer-sm" aria-hidden="true"></div>

<div class="employee-form-shell">
  <ol class="breadcrumb">
    <li><a href="/users/">{{t "users.allEmployees"}}</a></li>
    <li class="active">{{t "users.addEmployee"}}</li>
  </ol>

  <section class="admin-form-card employee-form-card" aria-labelledby="employee-details-heading">
    <h2 id="employee-details-heading" class="employee-section-title">{{t "userAdd.detailsTitle"}}</h2>
    <form class="form-horizontal" method="POST" action="/users/add/" id="add_new_user_form">
      <input type="hidden" name="_csrf" value="{{csrf_token}}">
      <div class="form-group">
        <label for="name_inp" class="col-sm-4 control-label">{{t "userDetails.firstName"}}</label>
        <div class="col-sm-5">
          <input class="form-control" id="name_inp" name="name" required value="{{employee.name}}">
        </div>
      </div>

      <div class="form-group">
        <label for="lastname_inp" class="col-sm-4 control-label">{{t "userDetails.lastName"}}</label>
        <div class="col-sm-5">
          <input class="form-control" id="lastname_inp" name="lastname" required value="{{employee.lastname}}">
        </div>
      </div>

      <div class="form-group">
        <label for="email_inp" class="col-sm-4 control-label">{{t "userDetails.emailAddress"}}</label>
        <div class="col-sm-5">
          <input class="form-control" id="email_inp" type="email" name="email_address" required value="{{employee.email}}" aria-describedby="email_help">
          <span id="email_help" class="help-block">{{t "userDetails.emailHelp"}}</span>
        </div>
      </div>

      <div class="form-group">
        <label for="select_inp" class="col-sm-4 control-label">{{t "userDetails.department"}}</label>
        <div class="col-sm-5">
          <select class="form-control" id="select_inp" name="department" aria-describedby="department_help">
            {{#each departments}}
                <option value="{{this.id}}" data-vpp="{{@index}}">{{this.name}}</option>
            {{/each}}
          </select>
          <span id="department_help" class="help-block">{{t "userDetails.departmentHelp"}}</span>
        </div>
      </div>

      <div class="form-group">
        <div class="col-sm-5 col-sm-offset-4">
          <div class="checkbox">
          <label for="admin_inp">
            <input id="admin_inp" name="admin" type="checkbox">
            {{t "userAdd.isAdminLabel"}}
          </label>
          </div>
        </div>
      </div>

      <div class="form-group">
        <div class="col-sm-5 col-sm-offset-4">
          <div class="checkbox">
          <label for="auto_approve_inp">
            <input id="auto_approve_inp" name="auto_approve" type="checkbox" aria-describedby="auto_approve_help">
            {{t "userDetails.autoApprove"}}
          </label>
          </div>
          <span id="auto_approve_help" class="help-block">{{t "userAdd.autoApproveHelp"}}</span>
        </div>
      </div>

      <div class="form-group">
        <label for="start_date_inp" class="col-sm-4 control-label">{{t "userDetails.startedOn"}}</label>
        <div class="col-sm-5 date">
          <input class="form-control" id="start_date_inp" type="text" name="start_date" required data-date-autoclose="1" data-provide="datepicker" data-date-format="{{#with logged_user.company }}{{this.get_default_date_format_for_date_picker}}{{/with}}" data-date-week-start="1" value="{{as_date booking_start}}" aria-describedby="start_date_help">
          <span id="start_date_help" class="help-block">{{t "userDetails.startDateHelp"}}</span>
        </div>
      </div>

      <div class="form-group">
        <label for="end_date_inp" class="col-sm-4 control-label">{{t "userDetails.endedOn"}}</label>
        <div class="col-sm-5 date">
          <input class="form-control" id="end_date_inp" type="text" name="end_date" data-date-autoclose="1" data-provide="datepicker" data-date-format="{{#with logged_user.company }}{{this.get_default_date_format_for_date_picker}}{{/with}}" data-date-week-start="1" value="{{as_date employee.end_date}}" aria-describedby="end_date_help">
          <span id="end_date_help" class="help-block employee-help-stack"><span>{{t "userDetails.endDateHelp" company=company.name}}</span><span>{{t "userDetails.endDateHelpAccess"}}</span><span>{{t "userDetails.endDateHelpDeactivate"}}</span></span>
        </div>
      </div>

      <div class="form-group">
        <label for="password_inp" class="col-sm-4 control-label">{{t "userDetails.password"}}</label>
        <div class="col-sm-5">
          <input class="form-control" id="password_inp" type="password" name="password_one" required value="" {{#if company.ldap_auth_enabled}} readonly {{/if}} aria-describedby="password_inp_help">
          <span id="password_inp_help" class="help-block">
          {{# if company.ldap_auth_enabled }}
            <a href="/settings/company/authentication/">{{t "userDetails.ldapLink"}}</a> {{t "userDetails.ldapEnabled"}}
          {{else}}
            {{t "userAdd.passwordHelp"}}
          {{/ if}}
          </span>
        </div>
      </div>

      <div class="form-group">
        <label for="confirm_password_inp" class="col-sm-4 control-label">{{t "userDetails.confirmPassword"}}</label>
        <div class="col-sm-5">
          <input class="form-control" id="confirm_password_inp" type="password" name="password_confirm" required value="" {{# if company.ldap_auth_enabled}}readonly{{/if}}>
        </div>
      </div>

      <div class="admin-form-actions">
        <a class="btn btn-link" href="/users/">{{t "common.cancel"}}</a>
        <button type="submit" id="add_new_user_btn" class="btn btn-success single-click">{{t "users.addEmployee"}}</button>
      </div>
    </form>
  </section>
</div>

</main>

{{> footer }}
