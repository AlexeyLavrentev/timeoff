{{> header }}

<h1>{{t "replacementsConfig.title"}}</h1>

<p class="lead">{{t "replacementsConfig.subtitle"}}</p>

{{> show_flash_messages }}

<div class="row main-row_header">
  <p class="col-md-12">{{t "common.description"}}</p>
</div>

<div class="row">
  <div class="col-md-8 col-md-offset-1">
    <p>{{t "replacementsConfig.description" company=company.name}}</p>
  </div>
</div>

<div class="row main-row_header">
  <p class="col-md-12">{{t "common.configuration"}}</p>
</div>

<div class="row">
  <div class="col-md-12">
    <form class="form-inline" method="get" action="">
      <div class="form-group">
        <label for="department_filter">{{t "replacementsConfig.departmentFilterLabel"}}</label>
        <select class="form-control" id="department_filter" name="department">
          <option value="">{{t "departments.allDepartments"}}</option>
          {{#each departments}}
            <option value="{{this.id}}" {{#if_equal this.id ../departmentFilter}}selected="selected"{{/if_equal}}>{{this.name}}</option>
          {{/each}}
        </select>
      </div>
      <button type="submit" class="btn btn-default">{{t "replacementsConfig.applyFilter"}}</button>
    </form>
  </div>
</div>

<div class="row">&nbsp;</div>

<div class="row">
  <div class="col-md-12">
    <form class="form-horizontal" action="" method="post">
      <div class="form-group">
        <label for="user_id" class="col-md-3 control-label">{{t "replacementsConfig.employeeLabel"}}</label>
        <div class="col-md-5">
          <select class="form-control" id="user_id" name="user_id" required>
            <option value="">{{t "common.selectOption"}}</option>
            {{#each users}}
              <option value="{{this.id}}">{{full_name this}} ({{this.email}})</option>
            {{/each}}
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="replacement_user_id" class="col-md-3 control-label">{{t "replacementsConfig.replacementLabel"}}</label>
        <div class="col-md-5">
          <select class="form-control" id="replacement_user_id" name="replacement_user_id" required>
            <option value="">{{t "common.selectOption"}}</option>
            {{#each users}}
              <option value="{{this.id}}">{{full_name this}} ({{this.email}})</option>
            {{/each}}
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="priority" class="col-md-3 control-label">{{t "replacementsConfig.priorityLabel"}}</label>
        <div class="col-md-2">
          <input class="form-control" id="priority" type="number" min="1" step="1" value="1" name="priority" required>
        </div>
        <div class="col-md-6">
          <span class="help-block">{{t "replacementsConfig.priorityHelp"}}</span>
        </div>
      </div>

      <div class="form-group">
        <div class="col-md-offset-3 col-md-5">
          <button type="submit" class="btn btn-success pull-right single-click">{{t "common.addNew"}}</button>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="row">&nbsp;</div>

<div class="row">
  <div class="col-md-12">
    <table class="table table-striped table-hover">
      <thead>
        <tr>
          <th>{{t "replacementsConfig.employeeLabel"}}</th>
          <th>{{t "replacementsConfig.replacementLabel"}}</th>
          <th>{{t "replacementsConfig.priorityLabel"}}</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#if rules.length}}
          {{#each rules}}
            <tr>
              <td>
                {{#if this.user}}
                  {{full_name this.user}} ({{this.user.email}})
                {{else}}
                  {{t "replacementsConfig.unknownUser"}}
                {{/if}}
              </td>
              <td>
                {{#if this.replacement}}
                  {{full_name this.replacement}} ({{this.replacement.email}})
                {{else}}
                  {{t "replacementsConfig.unknownUser"}}
                {{/if}}
              </td>
              <td>{{this.priority}}</td>
              <td class="text-right">
                <form method="post" action="/settings/company/replacements/delete/{{this.id}}/" style="display:inline;">
                  <button type="submit" class="btn btn-default single-click">{{t "common.remove"}}</button>
                </form>
              </td>
            </tr>
          {{/each}}
        {{else}}
          <tr>
            <td colspan="4">{{t "replacementsConfig.noRules"}}</td>
          </tr>
        {{/if}}
      </tbody>
    </table>
  </div>
</div>

{{> footer }}
