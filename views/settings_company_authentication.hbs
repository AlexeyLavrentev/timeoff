
{{> header }}

<h1>{{t "authConfig.title"}}</h1>
<p class="lead">{{t "authConfig.subtitle"}}</p>

{{> show_flash_messages }}

<div class="row main-row_header">
  <p class="col-md-12">{{t "authConfig.ldapSectionTitle"}}</p>
</div>

<div class="row">
  <div class="col-md-12">
    <form class="form-horizontal" action="" method="post">

      <div class="form-group">
        <div class="col-md-9 col-md-offset-3">
          <label for="ldap_auth_enabled" class="control-label">
            <input id="ldap_auth_enabled" type="checkbox" {{#if company.ldap_auth_enabled}}checked="checked"{{/if}} name="ldap_auth_enabled" />&nbsp;
            {{t "ldapAuth.enableLabel"}}
          </label>
        </div>
      </div>

      <div class="form-group">
        <label for="ldap_url" class="col-md-3 control-label">{{t "ldapAuth.urlLabel"}}</label>
        <div class="col-md-5">
          <input class="form-control" id="ldap_url" placeholder="ldap://ldap.forumsys.com:389" name="url" value="{{ldap_config.url}}" aria-describedby="ldap_url_help" >
        </div>
        <span id="ldap_url_help" class="help-block">{{t "ldapAuth.urlHelp"}}</span>
      </div>

      <div class="form-group">
        <div class="col-md-9 col-md-offset-3">
          <label for="allow_unauthorized_cert" class="control-label">
            <input id="allow_unauthorized_cert" type="checkbox" {{#if ldap_config.allow_unauthorized_cert}}checked="checked"{{/if}} name="allow_unauthorized_cert" />&nbsp;
            {{t "ldapAuth.allowUnauthorizedCert"}}
          </label>
        </div>
      </div>

      <div class="form-group">
        <label for="ldap_bindn" class="col-md-3 control-label">{{t "ldapAuth.bindDnLabel"}}</label>
        <div class="col-md-5">
          <input class="form-control" id="ldap_bindn" placeholder="cn=read-only-admin,dc=example,dc=com" name="binddn" value="{{ldap_config.binddn}}">
        </div>
      </div>

      <div class="form-group">
        <label for="ldap_password" class="col-md-3 control-label">{{t "ldapAuth.bindCredentialsLabel"}}</label>
        <div class="col-md-5">
          <input class="form-control" id="ldap_password" name="bindcredentials" value="{{ldap_config.bindcredentials}}" type="password" aria-describedby="ldap_password_help">
        </div>
        <span id="ldap_password_help" class="help-block">{{t "ldapAuth.bindCredentialsHelp"}}</span>
      </div>

      <div class="form-group">
        <label for="ldap_search_base" class="col-md-3 control-label">{{t "ldapAuth.searchBaseLabel"}}</label>
        <div class="col-md-5">
          <input class="form-control" id="ldap_search_base" placeholder="dc=example,dc=com" name="searchbase" value="{{ldap_config.searchbase}}">
        </div>
      </div>

      <div class="form-group">
        <label for="current_user_password" class="col-md-3 control-label">{{t "ldapAuth.currentPasswordLabel"}}</label>
        <div class="col-md-5">
          <input class="form-control" id="current_user_password" name="password_to_check" value="" type="password" aria-describedby="current_user_password_help">
        </div>
        <span id="current_user_password_help" class="help-block">{{t "ldapAuth.currentPasswordHelpPrefix"}} <strong>{{#with logged_user}}{{this.full_name}}{{/with}}</strong> {{t "ldapAuth.currentPasswordHelpSuffix"}}</span>
      </div>

      <hr/>

      <div class="row main-row_header">
        <p class="col-md-12">{{t "authConfig.ssoSectionTitle"}}</p>
      </div>

      <div class="form-group">
        <div class="col-md-9 col-md-offset-3">
          <label for="sso_auth_enabled" class="control-label">
            <input id="sso_auth_enabled" type="checkbox" {{#if company.sso_auth_enabled}}checked="checked"{{/if}} name="sso_auth_enabled" />&nbsp;
            {{t "authConfig.enableSsoLabel"}}
          </label>
        </div>
      </div>

      <div class="form-group">
        <label for="sso_auth_provider" class="col-md-3 control-label">{{t "authConfig.providerLabel"}}</label>
        <div class="col-md-5">
          <select class="form-control" id="sso_auth_provider" name="sso_auth_provider">
            <option value="oidc" {{#if_equal sso.provider "oidc"}}selected{{/if_equal}}>OIDC</option>
            <option value="saml" {{#if_equal sso.provider "saml"}}selected{{/if_equal}}>SAML 2.0</option>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="sso_issuer_url" class="col-md-3 control-label">{{t "authConfig.oidcIssuerLabel"}}</label>
        <div class="col-md-5">
          <input class="form-control" id="sso_issuer_url" name="sso_issuer_url" value="{{sso.config.issuer_url}}" placeholder="https://keycloak.example.com/realms/myrealm">
        </div>
      </div>

      <div class="form-group">
        <label for="sso_client_id" class="col-md-3 control-label">{{t "authConfig.oidcClientIdLabel"}}</label>
        <div class="col-md-5">
          <input class="form-control" id="sso_client_id" name="sso_client_id" value="{{sso.config.client_id}}" placeholder="timeoff-management">
        </div>
      </div>

      <div class="form-group">
        <label for="sso_client_secret" class="col-md-3 control-label">{{t "authConfig.oidcClientSecretLabel"}}</label>
        <div class="col-md-5">
          <input class="form-control" id="sso_client_secret" name="sso_client_secret" value="{{sso.config.client_secret}}" type="password">
        </div>
      </div>

      <div class="form-group">
        <label for="sso_scope" class="col-md-3 control-label">{{t "authConfig.oidcScopeLabel"}}</label>
        <div class="col-md-5">
          <input class="form-control" id="sso_scope" name="sso_scope" value="{{sso.config.scope}}" placeholder="openid profile email">
        </div>
      </div>

      <div class="form-group">
        <label for="sso_email_claim" class="col-md-3 control-label">{{t "authConfig.oidcEmailClaimLabel"}}</label>
        <div class="col-md-5">
          <input class="form-control" id="sso_email_claim" name="sso_email_claim" value="{{sso.config.email_claim}}" placeholder="email">
        </div>
      </div>

      <div class="form-group">
        <div class="col-md-9 col-md-offset-3">
          <label for="sso_require_verified_email" class="control-label">
            <input id="sso_require_verified_email" type="checkbox" {{#if sso.config.require_verified_email}}checked="checked"{{/if}} name="sso_require_verified_email" />&nbsp;
            {{t "authConfig.oidcRequireVerifiedEmailLabel"}}
          </label>
        </div>
      </div>

      <hr/>

      <div class="form-group">
        <label for="sso_entry_point" class="col-md-3 control-label">{{t "authConfig.samlEntryPointLabel"}}</label>
        <div class="col-md-5">
          <input class="form-control" id="sso_entry_point" name="sso_entry_point" value="{{sso.config.entry_point}}" placeholder="https://keycloak.example.com/realms/myrealm/protocol/saml">
        </div>
      </div>

      <div class="form-group">
        <label for="sso_idp_cert" class="col-md-3 control-label">{{t "authConfig.samlIdpCertLabel"}}</label>
        <div class="col-md-5">
          <textarea class="form-control" id="sso_idp_cert" name="sso_idp_cert" rows="6" placeholder="-----BEGIN CERTIFICATE-----">{{sso.config.idp_cert}}</textarea>
        </div>
      </div>

      <div class="form-group">
        <label for="sso_identifier_format" class="col-md-3 control-label">{{t "authConfig.samlIdentifierFormatLabel"}}</label>
        <div class="col-md-5">
          <input class="form-control" id="sso_identifier_format" name="sso_identifier_format" value="{{sso.config.identifier_format}}" placeholder="urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress">
        </div>
      </div>

      <div class="form-group">
        <label for="sso_email_attribute" class="col-md-3 control-label">{{t "authConfig.samlEmailAttributeLabel"}}</label>
        <div class="col-md-5">
          <input class="form-control" id="sso_email_attribute" name="sso_email_attribute" value="{{sso.config.email_attribute}}" placeholder="email">
        </div>
      </div>

      <div class="form-group">
        <label for="sso_sp_entity_id" class="col-md-3 control-label">{{t "authConfig.samlEntityIdLabel"}}</label>
        <div class="col-md-5">
          <input class="form-control" id="sso_sp_entity_id" name="sso_sp_entity_id" value="{{sso.config.sp_entity_id}}" placeholder="{{sso.saml_entity_id}}">
        </div>
      </div>

      <div class="form-group">
        <label class="col-md-3 control-label">{{t "authConfig.samlCallbackLabel"}}</label>
        <div class="col-md-5">
          <p class="form-control-static"><code>{{sso.saml_callback_url}}</code></p>
        </div>
      </div>

      <div class="form-group">
        <label class="col-md-3 control-label">{{t "authConfig.samlMetadataLabel"}}</label>
        <div class="col-md-5">
          <p class="form-control-static"><code>{{sso.saml_metadata_url}}</code></p>
        </div>
      </div>

      <div class="form-group">
        <label class="col-md-3 control-label">{{t "authConfig.oidcCallbackLabel"}}</label>
        <div class="col-md-5">
          <p class="form-control-static"><code>{{sso.oidc_callback_url}}</code></p>
        </div>
      </div>

      <div class="form-group">
        <div class="col-md-offset-3 col-md-5">
          <button id="submit_registration" type="submit" class="pull-right btn btn-success single-click">{{t "authConfig.saveButton"}}</button>
        </div>
      </div>

    </form>
  </div>
</div>

{{> footer }}
