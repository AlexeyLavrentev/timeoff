
{{> header }}

<h1>{{t "resetPassword.title"}}</h1>

{{> show_flash_messages }}

<div class="auth-shell">
<div class="auth-card">
<form class="form-horizontal" action="/reset-password/" method="post">
  <input type="hidden" name="_csrf" value="{{csrf_token}}">

  <input type="hidden" name="t" value="{{token}}">

  <div class="form-group">
    <label for="password_inp" class="col-sm-4 control-label">{{t "resetPassword.newPassword"}}</label>
    <div class="col-sm-8">
      <input class="form-control" id="password_inp" type="password" name="password">
    </div>
  </div>

  <div class="form-group">
    <label for="confirm_password_inp" class="col-sm-4 control-label">{{t "resetPassword.confirmPassword"}}</label>
    <div class="col-sm-8">
      <input class="form-control" id="confirm_password_inp" type="password" name="confirm_password">
    </div>
  </div>

  <div class="form-group">
    <div class="col-sm-offset-4 col-sm-8">
      <button type="submit" class="btn btn-success single-click" id="submit_login">{{t "common.save"}}</button>
    </div>
  </div>

</form>
</div>
</div>

{{> footer }}
