
{{> header }}

<a class="sr-only sr-only-focusable" href="#main-content">{{t "nav.skipToMainContent"}}</a>
<main id="main-content" tabindex="-1">
<h1>{{t "requests.messagesTitle" name=logged_user.name lastname=logged_user.lastname}}</h1>

{{> show_flash_messages }}

<div class="row main-row_header">
  <p class="col-md-12">{{t "requests.toApproveTitle"}}</p>
</div>

<div class="row">
  {{# unless to_be_approved_leaves}}
  <div class="col-md-12 text-muted">
    {{t "requests.noRequestsToApprove"}}
  </div>
  {{else}}
  <div class="col-md-12">
    <div class="table-responsive mobile-card-table-container" role="region" aria-label="{{t "requests.toApproveTitle"}}" tabindex="0">
    <table class="table table-hover requests-to-approve-table mobile-card-table">
      <caption class="sr-only">{{t "requests.toApproveTitle"}}</caption>
      <thead>
        <tr>
          <th class="bulk-select-cell">
            <input type="checkbox" class="bulk-select-all" aria-label="{{t "requests.selectAll"}}">
          </th>
          <th>{{t "requests.employee"}}</th>
          <th>{{t "requests.department"}}</th>
          <th>{{t "requests.requestDate"}}</th>
          <th>{{t "requests.leaveDates"}}</th>
          <th>{{t "requests.type"}}</th>
          <th>{{t "requests.days"}}</th>
          <th class="col-xs-2">{{t "requests.comment"}}</th>
          <th colspan="2"></th>
        </tr>
      </thead>
      <tbody>
        {{#each to_be_approved_leaves }}
        <tr vpp="pending_for__{{this.user.email}}">
          <td class="bulk-select-cell mobile-card-select">
            <input type="checkbox" class="bulk-request-checkbox" name="request" value="{{this.id}}" form="bulk-action-form" aria-label="{{t "requests.selectRow"}}">
          </td>
          <td data-label="{{t 'requests.employee'}}"><span class="mobile-card-value">{{#with this.user}}{{this.full_name}}
            <button type="button" class="user-details-summary-trigger requests-user-details-summary-trigger details-trigger-button" data-user-id="{{this.id}}" aria-label="{{t 'user.employeeSummary'}}: {{this.full_name}}"><span class="fa fa-question-circle" aria-hidden="true"></span></button>{{/with}}</span>
          </td>
          <td data-label="{{t 'requests.department'}}">{{this.user.department.name}}</td>
          <td class="date_of_request" data-label="{{t 'requests.requestDate'}}">{{as_date_from_timestamp this.createdAt}}</td>
          <td data-label="{{t 'requests.leaveDates'}}" data-tom-leave-dates="1"><a class="leave-details-summary-trigger" data-leave-id="{{this.id}}" href="#">{{> leave_dates leave=this}}</a></td>
          <td data-label="{{t 'requests.type'}}"><span class="mobile-card-value">
            {{#if this.is_pended_revoke_leave}}{{t "requests.revokeLabel"}} {{/if}}{{this.leave_type.name}}
            {{#if this.minimum_leave_warning}}
              <div class="text-warning small">{{this.minimum_leave_warning}}</div>
            {{/if}}
          </span></td>
          <td data-label="{{t 'requests.days'}}" data-vpp="days_used">{{ this.get_deducted_days_number }}</td>
          <td data-label="{{t 'requests.comment'}}">{{this.comment.comment}}</td>
          <td class="mobile-card-action">
            <form action="/requests/reject/" method="POST">
              <input type="hidden" name="_csrf" value="{{@root.csrf_token}}">
            <input class="btn btn-warning single-click" type="submit" value="{{t "requests.reject"}}">
            <input type="hidden" value="{{this.id}}" name="request">
            </form>
          </td>
          <td class="mobile-card-action">
            <form action="/requests/approve/" method="POST">
              <input type="hidden" name="_csrf" value="{{@root.csrf_token}}">
            <input class="btn btn-success single-click" type="submit" value="{{t "requests.approve"}}">
            <input type="hidden" value="{{this.id}}" name="request">
            </form>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    </div>

    <form id="bulk-action-form" class="bulk-action-bar" method="POST" action="/requests/bulk/approve/" style="margin-top: 10px;">
      <input type="hidden" name="_csrf" value="{{@root.csrf_token}}">
      <button type="submit" formaction="/requests/bulk/approve/" class="btn btn-success bulk-approve-btn" disabled>{{t "requests.approveSelected"}}</button>
      <button type="submit" formaction="/requests/bulk/reject/" class="btn btn-warning bulk-reject-btn" disabled>{{t "requests.rejectSelected"}}</button>
      <span class="text-muted bulk-selected-count" aria-live="polite"></span>
    </form>
  </div>
  {{/unless}}
</div>


<div class="main-row_header">&nbsp;</div>

<div class="row main-row_header">
  <p class="col-md-12">{{t "requests.allAbsences"}}</p>
</div>

{{> user_requests_grouped grouped_leaves=my_leaves_grouped logged_user=logged_user }}

</main>

<script>
(function() {
  var form = document.getElementById('bulk-action-form');
  if (!form) { return; }

  var selectAll = document.querySelector('.bulk-select-all');
  var checkboxes = [].slice.call(document.querySelectorAll('.bulk-request-checkbox'));
  var approveBtn = form.querySelector('.bulk-approve-btn');
  var rejectBtn = form.querySelector('.bulk-reject-btn');
  var counter = form.querySelector('.bulk-selected-count');
  var countTemplate = "{{t "requests.selectedCount"}}";

  function selectedCount() {
    return checkboxes.filter(function(cb) { return cb.checked; }).length;
  }

  function refresh() {
    var count = selectedCount();
    var hasSelection = count > 0;

    approveBtn.disabled = !hasSelection;
    rejectBtn.disabled = !hasSelection;
    counter.textContent = hasSelection ? countTemplate.replace('{count}', count) : '';

    if (selectAll) {
      selectAll.checked = count > 0 && count === checkboxes.length;
      selectAll.indeterminate = count > 0 && count < checkboxes.length;
    }
  }

  if (selectAll) {
    selectAll.addEventListener('change', function() {
      checkboxes.forEach(function(cb) { cb.checked = selectAll.checked; });
      refresh();
    });
  }

  checkboxes.forEach(function(cb) {
    cb.addEventListener('change', refresh);
  });

  refresh();
})();
</script>

{{>footer}}
