{{> header }}

<h1>{{t "login.ssoTitle"}}</h1>
<p class="lead">{{t "login.ssoSubtitle"}}</p>

{{> show_flash_messages }}

<div class="auth-shell">
<div class="auth-card">
{{#if sso_login.direct_sso_available}}
<form class="form-horizontal" action="{{sso_login.direct_sso_url}}" method="get" id="sso_direct_form">

  <div class="form-group">
    <div class="col-sm-12">
      <p class="help-block">{{t "login.ssoDirectHint" company=sso_login.direct_sso_company_name provider=sso_login.direct_sso_provider_label}}</p>
      <button type="submit" class="btn btn-success single-click" id="submit_sso_direct">{{t "login.continueWithSso"}}</button>
    </div>
  </div>

</form>
{{/if}}

<form class="form-horizontal" action="/login/sso" method="post" id="sso_discovery_form">
  <input type="hidden" name="_csrf" value="{{csrf_token}}">

  <div class="form-group">
    <div class="col-sm-12">
      <h3>{{t "login.ssoEmailSectionTitle"}}</h3>
    </div>
  </div>

  <div class="form-group">
    <label for="sso_email_inp" class="col-sm-4 control-label">{{t "login.employeeEmail"}}</label>
    <div class="col-sm-8">
      <input class="form-control" id="sso_email_inp" type="text" name="email" required>
      <span class="help-block">{{t "login.ssoHint"}}</span>
    </div>
  </div>

  <div class="form-group">
    <div class="col-sm-offset-4 col-sm-8 auth-actions">
      <button type="submit" class="btn btn-success single-click" id="submit_sso_login">{{t "login.continueWithSso"}}</button>
      <a href="/login/" class="btn btn-link" id="back_to_password_login">{{t "login.backToPasswordLogin"}}</a>
    </div>
  </div>

</form>
</div>
</div>

{{> footer }}
