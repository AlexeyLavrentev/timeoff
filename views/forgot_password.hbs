
{{> header }}

<h1>{{t "forgotPassword.title"}}</h1>

{{> show_flash_messages }}

{{#if sso_login.has_sso_companies }}
<div class="alert alert-info" role="alert">
  {{t "forgotPassword.ssoHint"}}
  <a href="/login/sso/">{{t "login.continueWithSso"}}</a>
</div>
{{/if}}

<div class="auth-shell">
<div class="auth-card">
<form class="form-horizontal" action="/forgot-password/" method="post">
  <input type="hidden" name="_csrf" value="{{csrf_token}}">

  <div class="form-group">
    <label for="email_inp" class="col-sm-4 control-label">{{t "forgotPassword.employeeEmail"}}</label>
    <div class="col-sm-8">
      <input class="form-control" id="email_inp" type="text" name="email" required>
    </div>
  </div>


  <div class="form-group">
    <div class="col-sm-offset-4 col-sm-8">
      <button type="submit" class="btn btn-success single-click" id="submit_login">{{t "forgotPassword.submit"}}</button>
    </div>
  </div>

</form>
</div>
</div>

{{> footer }}
