<!DOCTYPE html>
<html lang="{{locale}}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="{{t 'meta.description'}}">
    <meta name="google-site-verification" content="DUsMFaxswq0M9hZwfzXPVMP56hDyUDG_0bLDZFR6zA4" />
    <link rel="icon" href="{{branding.faviconUrl}}" sizes="any">
    <link rel="shortcut icon" href="{{branding.faviconUrl}}">
    <link rel="icon" type="image/png" href="{{branding.faviconPng32Url}}">
    <link rel="icon" type="image/png" href="{{branding.faviconPng16Url}}">
    <link rel="icon" type="image/png" href="{{branding.appIconUrl}}" sizes="512x512">
    <link rel="apple-touch-icon" href="{{branding.appleTouchIconUrl}}">
    <link rel="manifest" href="{{branding.manifestUrl}}">
    <link rel="stylesheet" type="text/css" href="//fonts.googleapis.com/css?family=Open+Sans:700,600,400,300"/>

    <title>{{#if title}}{{title}}{{else}}{{brand_name}}{{/if}}</title>

    <script>
      (function() {
        try {
          var theme = localStorage.getItem('timeoff-theme');
          if (theme === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        } catch (e) {
          // Ignore theme preferences when storage is unavailable.
        }
      })();
    </script>

    <!-- Bootstrap core CSS -->
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/font-awesome.min.css">

    <!-- Custom styles for this template -->
    <link rel='stylesheet' href='/css/style.css' />
    {{#each custom_css}}
    <link rel="stylesheet" href="{{this}}" />
    {{/each}}
  </head>

  <body>
    <div class="{{#if team_view_full_width}}container-fluid{{else}}container{{/if}} app-container{{#if team_view_full_width}} team-view-container{{/if}}">
    {{{body}}}
    </div>

    <script src="/js/jquery.min.js"></script>
    <script src="/js/bootstrap.min.js"></script>
    <script>
      window.timeoff = {
        locale: "{{locale}}",
        csrfToken: {{{json csrf_token}}},
        disableNotifications: {{#if disable_notifications}}true{{else}}false{{/if}},
        features: {{{json features}}},
        branding: {{{json branding}}},
        translations: {
          loading: "{{t "common.loading"}}",
          requestFailed: "{{t "errors.requestFailed"}}",
          employeeSummary: "{{t "user.employeeSummary"}}",
          leaveSummary: "{{t "leave.leaveSummary"}}",
          notificationsEmpty: "{{t "nav.notificationsEmpty"}}",
          datepicker: {{{json (t "datepicker" returnObjects=true)}}}
        }
      };
    </script>
    {{~#each custom_java_script~}}
      <script src="{{this}}"></script>
    {{~/each~}}

    {{~# is_ga_analitics_on ~}}
      <script>
        (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
        (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),
        m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
        })(window,document,'script','//www.google-analytics.com/analytics.js','ga');
        ga('create', 'UA-63733147-1', 'auto');
        ga('send', 'pageview');
      </script>
    {{~/ is_ga_analitics_on ~}}

  </body>
</html>
