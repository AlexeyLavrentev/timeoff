
<td class="calendar_cell half_1st day_{{ day.val }}
    {{#if day.is_calendar_weekend}}calendar_weekend_cell{{/if}}
    {{#if day.is_bank_holiday}}bank_holiday_cell{{/if}}
    {{#if day.is_weekend}}weekend_cell{{/if}}
    {{#if day.is_leave_morning }}
        {{#if day.is_new_leave}}
            leave_cell_pended
        {{else}}
            leave_cell
            {{day.leave_color_class_morning}}
        {{/if}}
    {{/if}}
    {{# if day.is_current_day }}current_day_cell{{/if}}
">
{{#if day.leave_obj}}
  <button type="button"
    class="leave-details-summary-trigger interactive-leave-details-summary-trigger calendar-leave-details-trigger"
    data-leave-id="{{day.leave_obj.id}}"
    aria-expanded="false"
    aria-label="{{t 'leave.leaveSummary'}}: {{as_date_formatted day.moment 'D MMMM YYYY'}}"
    data-original-title="
      {{~#if day.leaveLabel ~}}{{~day.leaveLabel~}}: {{/if~}}
      {{~#if day.is_current_day}}{{t "calendar.tooltip.today"}}{{/if~}}
      {{~#if day.leave_obj.is_new_leave}}{{t "calendar.tooltip.newAbsencePendingApproval"}}{{/if~}}
      {{~#if day.leave_obj.is_pended_revoke_leave}}{{t "calendar.tooltip.revokedPendingApproval"}}{{/if~}}
      {{~#if day.leave_obj.is_approved_leave~}}
        {{~#unless day.leave_obj.is_pended_revoke_leave}}{{t "calendar.tooltip.approvedAbsence"}}{{/unless~}}
      {{~/if}}"
  >{{day.val}}</button>
{{else}}
  <span
    {{#if day.is_current_day}}
      data-toggle="tooltip"
      data-placement="top"
      title="{{t "calendar.tooltip.today"}}"
    {{/if}}

    {{#if day.is_bank_holiday}}
      data-toggle="tooltip"
      data-placement="top"
      title="{{t "calendar.tooltip.bankHoliday" name=day.bank_holiday_name}}"
    {{/if}}
  >{{day.val}}</span>
{{/if}}
</td>
<td class="calendar_cell half_2nd day_{{ day.val }}
    {{#if day.is_calendar_weekend}}calendar_weekend_cell{{/if}}
    {{#if day.is_bank_holiday}}bank_holiday_cell{{/if}}
    {{#if day.is_weekend}}weekend_cell{{/if}}
    {{#if day.is_leave_afternoon }}
        {{#if day.is_new_leave}}
            leave_cell_pended
        {{else}}
            leave_cell
            {{day.leave_color_class_afternoon}}
        {{/if}}
    {{/if}}
    {{# if day.is_current_day }}current_day_cell{{/if}}
"></td>
