<td class="calendar_cell half_1st day_{{day.val}}{{#if day.is_calendar_weekend}} calendar_weekend_cell{{/if}}{{#if day.is_bank_holiday}} bank_holiday_cell{{/if}}{{#if day.is_weekend}} weekend_cell{{/if}}{{#if day.is_leave_morning}}{{#if day.is_new_leave}} leave_cell_pended{{else}} leave_cell {{day.leave_color_class_morning}}{{/if}}{{/if}}{{#if day.is_current_day}} current_day_cell{{/if}}"><span{{#unless day.is_bank_holiday}}{{#unless day.is_weekend}}{{#if day.leave_obj}} class="leave-details-summary-trigger" data-leave-id="{{day.leave_obj.id}}"{{/if}}{{/unless}}{{/unless}}{{#if day.is_current_day}} data-toggle="tooltip" data-placement="top" title="{{t "calendar.tooltip.today"}}"{{/if}}{{#if day.is_bank_holiday}} data-toggle="tooltip" data-placement="top" title="{{t "calendar.tooltip.bankHoliday" name=day.bank_holiday_name}}"{{/if}}>{{day.val}}</span></td>
<td class="calendar_cell half_2nd day_{{day.val}}{{#if day.is_calendar_weekend}} calendar_weekend_cell{{/if}}{{#if day.is_bank_holiday}} bank_holiday_cell{{/if}}{{#if day.is_weekend}} weekend_cell{{/if}}{{#if day.is_leave_afternoon}}{{#if day.is_new_leave}} leave_cell_pended{{else}} leave_cell {{day.leave_color_class_afternoon}}{{/if}}{{/if}}{{#if day.is_current_day}} current_day_cell{{/if}}"></td>
