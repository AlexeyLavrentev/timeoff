<div class="row clearfix">
  <div class="team-view-table-shell">
    <div class="col-md-12 team-view-table-container" role="region" aria-label="{{department.departmentName}}" tabindex="0">
      <table class="team-view-table table-hover">
        <caption class="sr-only">{{department.departmentName}}</caption>
        <thead>
        <tr>
          <th class="team-view-header team-view-name-header" colspan="2" scope="colgroup">
            <div>
              <h3>{{department.departmentName}}</h3>
            </div>
          </th>

        {{#each department.header_days }}
          <th colspan="2" scope="col" class="team-view-header{{#if (is_calendar_weekend this.moment)}} calendar_weekend_header{{/if}}">
            <div class="team-view-weekday">{{as_date_formatted this.moment 'ddd'}}</div>
          </th>
        {{/each}}
        </tr>
        </thead>

        <tbody>
        {{#each department.users_and_leaves as |employeeRow|}}
          <tr class="teamview-user-list-row" data-vpp-user-list-row={{employeeRow.user.id}}>
            <td class="left-column-cell cross-link" data-user-id={{employeeRow.user.id}}>
              <span class="team-view-employee-cell">
                {{#if ../logged_user.admin}}<a class="team-view-employee-link" href="/users/edit/{{employeeRow.user.id}}/">{{full_name employeeRow.user}}</a>{{else}}<span class="team-view-employee-name">{{full_name employeeRow.user}}</span>{{/if}}
                <button type="button" class="user-details-summary-trigger interactive-user-details-summary-trigger team-view-user-details-summary-trigger details-trigger-button" data-user-id="{{employeeRow.user.id}}" aria-label="{{t 'user.employeeSummary'}}: {{full_name employeeRow.user}}"><span class="fa fa-question-circle" aria-hidden="true"></span></button>
              </span>
            </td>
            <td class="team-view-deducted-cell">
              {{#if employeeRow.statistics}}
              <button
                type="button"
                class="teamview-deducted-days interactive-teamview-deducted-days-trigger team-view-deducted-days-trigger"
                data-content="{{t 'teamView.deductedDays' period=../deducted_period name=(full_name employeeRow.user) days=employeeRow.statistics.deducted_days}}"
                aria-label="{{t 'teamView.deductedDays' period=../deducted_period name=(full_name employeeRow.user) days=employeeRow.statistics.deducted_days}}"
                aria-expanded="false"
              >
                <span aria-hidden="true">{{employeeRow.statistics.deducted_days}}</span>
              </button>
              {{/if}}
            </td>
            {{#each employeeRow.days}}
              {{> team_view_calendar_cell day=this employee=employeeRow.user}}
            {{/each}}
          </tr>
        {{/each}}
        </tbody>
      </table>
    </div>

    <span class="team-view-scroll-cue" aria-hidden="true">
      <span class="fa fa-chevron-right" aria-hidden="true"></span>
    </span>
  </div>
</div>
