
  <form method="POST" action="/users/edit/{{employee.id}}/" class="admin-form-card employee-absence-card">
    <input type="hidden" name="_csrf" value="{{csrf_token}}">

  <input type="hidden" name="back_to_absences" value="1">
  <input type="hidden" name="name" value="{{employee.name}}">
  <input type="hidden" name="lastname" value="{{employee.lastname}}">
  <input type="hidden" name="email_address" value="{{employee.email}}">
  <input type="hidden" name="department" value="{{employee.DepartmentId}}">
  <input type="hidden" name="admin" value="{{#if employee.admin}}1{{else}}0{{/if}}">
  <input type="hidden" name="start_date" value="{{as_date employee.start_date}}">
  <input type="hidden" name="end_date" value="{{as_date employee.end_date}}">

  {{> user_details/breadcrumb employee=employee }}

  <div class="form-group">
    <h2 class="employee-section-title">{{t "absences.overview"}}</h2>
    <div class="progress bigger employee-allowance-progress">
      <div
        class="progress-bar progress-bar-success"
        style="width: {{ leave_statistics.used_so_far_percent }}%"
        data-content="{{t 'absences.usedSoFarPopover' name=(full_name employee) days=leave_statistics.used_so_far}}"
        data-placement="top"
        data-toggle="popover"
        data-trigger="focus hover"
        role="progressbar"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="{{ leave_statistics.used_so_far_percent }}"
        aria-label="{{t "absences.usedSoFarLabel" days=leave_statistics.used_so_far}}"
        tabindex="0"
      >
        {{#if leave_statistics.used_so_far_percent}}{{t "absences.usedSoFarLabel" days=leave_statistics.used_so_far}}{{/if}}
      </div>
      <div
        class="progress-bar progress-bar-warning"
        style="width: {{ leave_statistics.remaining_percent }}%"
        data-content="{{t 'absences.remainingPopover' name=(full_name employee) days=leave_statistics.remaining}}"
        data-placement="top"
        data-toggle="popover"
        data-trigger="focus hover"
        role="progressbar"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="{{ leave_statistics.remaining_percent }}"
        aria-label="{{t "absences.remainingLabel" days=leave_statistics.remaining}}"
        tabindex="0"
      >
        {{#if leave_statistics.remaining_percent}}{{t "absences.remainingLabel" days=leave_statistics.remaining}}{{/if}}
      </div>
    </div>
  </div>

  <div class="form-group">
    <label class="control-label">{{t "absences.daysAvailableForYear" name=employee.name}}</label>
    <p>{{t "absences.outOfAllowance" available=user_allowance.number_of_days_available_in_allowance total=user_allowance.total_number_of_days_in_allowance}}</p>
    <input id="days_remaining_inp" type="hidden" value="{{t "absences.outOfAllowance" available=user_allowance.number_of_days_available_in_allowance total=user_allowance.total_number_of_days_in_allowance}}">
  </div>

  <div class="form-group">
    <label class="control-label">{{t "absences.isAccruedAllowance"}}</label>
    <p>{{# if user_allowance.is_accrued_allowance }}{{t "common.yes"}}{{else}}{{t "common.no"}}{{/if}}</p>
    <span class="help-block">
      {{t "absences.accruedHelp"}} <a href="/settings/departments/edit/{{employee.DepartmentId}}">{{t "common.moreDetails"}} <i class="fa fa-angle-double-right" aria-hidden="true"></i></a>
    </span>
  </div>

  <div class="row employee-absence-summary">
    <div class="col-sm-6">
      <dl>
        <dt>{{t "absences.groupedByType"}}</dt>
        {{# if leave_type_statistics }}
          {{# each leave_type_statistics }}
            <dd><em>{{this.leave_type.name}}:</em> <span class="pull-right">{{this.days_taken}}{{# if this.limit}} {{t "common.outOf" limit=this.limit}}{{/if}}</span></dd>
          {{/each}}
        {{else}}
          <dd class="text-muted">{{t "calendar.noApprovedRequests"}}</dd>
        {{/if}}
      </dl>
    </div>

    <div class="col-sm-6">
      {{> user_details/allowance_breakdown user_allowance = user_allowance }}
    </div>
  </div>

  <div class="form-group">
    <label for="carried_over_allowance_inp" class="control-label">{{t "absences.carriedOver"}}</label>
    <div class="input-group employee-number-field">
      <input class="form-control" readonly id="carried_over_allowance_inp" type="number" step="0.5" name="carried_over_allowance" value="{{#if carried_over_allowance }}{{carried_over_allowance}}{{else}}0{{/if}}" aria-describedby="carried_over_allowance_help">
      <span class="input-group-addon">{{t "absences.workingDays"}}</span>
    </div>
    <div id="carried_over_allowance_help" class="help-block">
      <div>{{t "absences.carriedOverHelp"}}</div>
      <div>{{t "absences.carriedOverHelpSecond"}}</div>
    </div>
  </div>

  <div class="form-group">
    <label for="adjustment_inp" class="control-label">{{t "absences.adjustment"}}</label>
    <div class="input-group employee-number-field">
      <input class="form-control" id="adjustment_inp" type="number" step="0.5" name="adjustment" value="{{#if employee_adjustment }}{{employee_adjustment}}{{else}}0{{/if}}" aria-describedby="adjustment_help">
      <span class="input-group-addon">{{t "absences.workingDays"}}</span>
    </div>
    <div id="adjustment_help" class="help-block">
      <div>{{t "absences.adjustmentHelp"}}</div>
      <div>{{t "absences.adjustmentHelpSecond"}}</div>
      <div>{{t "absences.adjustmentHelpThird"}}</div>
    </div>
  </div>

  <div class="admin-form-actions">
    <button id="save_changes_btn" type="submit" class="btn btn-success single-click">{{t "common.saveChanges"}}</button>
  </div>
  </form>

  <div class="content-spacer" aria-hidden="true"></div>

  {{> user_requests_grouped grouped_leaves=grouped_leaves logged_user=logged_user }}
