
  <form method="POST" action="/settings/schedule" id="company_schedule_form" class="admin-form-card employee-schedule-card">
    <input type="hidden" name="_csrf" value="{{csrf_token}}">
  <input type="hidden" name="user_id" value="{{employee.id}}">

  {{> user_details/breadcrumb employee=employee }}

  <fieldset class="employee-schedule-fieldset">
    <legend class="employee-section-title">{{t "schedule.title"}}</legend>

    <p class="help-block">
      {{# with schedule }}
      {{# if (is_user_specific) }}
        {{t "schedule.userSpecificPrefix"}} <strong data-vpp="declare-user-specific-schedule">{{t "schedule.userSpecificEmphasis"}}</strong> {{t "schedule.userSpecificSuffix"}}
      {{else}}
        {{t "schedule.companyWidePrefix"}} <strong><a data-vpp="link-to-company-schedule" href="/settings/general/">{{t "schedule.companyWideLink"}}</a></strong> {{t "schedule.companyWideSuffix"}}
      {{/if}}
      {{/with}}
    </p>

    <div class="employee-schedule-widget">
      {{> schedule_widget }}
    </div>

  </fieldset>
  <div class="admin-form-actions">
    {{# with schedule }}
    {{# if (is_user_specific) }}
      <button type="submit" name="revoke_user_specific_schedule" class="btn btn-default">{{t "schedule.moveToCompanyWide"}}</button>
      <button type="submit" name="save_user_specific_schedule" class="btn btn-success">{{t "schedule.saveUserSpecific"}}</button>
    {{else}}
      <button type="submit" name="save_user_specific_schedule" class="btn btn-success">{{t "schedule.overrideCompanyWide"}}</button>
    {{/if}}
    {{/with}}
  </div>
  </form>
