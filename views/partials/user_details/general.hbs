
<form method="POST" action="/users/edit/{{employee.id}}/" class="admin-form-card employee-form-card">
  <input type="hidden" name="_csrf" value="{{csrf_token}}">

  {{> user_details/breadcrumb employee=employee }}

  <div class="form-group">
    <label for="name_inp" class="control-label">{{t "userDetails.firstName"}}</label>
    <input class="form-control" id="name_inp" name="name" required value="{{employee.name}}">
  </div>

  <div class="form-group">
    <label for="lastname_inp" class="control-label">{{t "userDetails.lastName"}}</label>
    <input class="form-control" id="lastname_inp" name="lastname" required value="{{employee.lastname}}">
  </div>

  <div class="form-group">
    <label for="email_inp" class="control-label">{{t "userDetails.emailAddress"}}</label>
    <input class="form-control" id="email_inp" type="email" name="email_address" required value="{{employee.email}}" aria-describedby="email_help">
    <span id="email_help" class="help-block">{{t "userDetails.emailHelp"}}</span>
  </div>

  <div class="form-group">
    <label for="select_inp" class="control-label">{{t "userDetails.department"}}</label>
    <select class="form-control" id="select_inp" name="department" aria-describedby="department_help">
      {{#each departments}}
          <option value="{{this.id}}" {{#if_equal ../employee.DepartmentId this.id}} selected="selected"{{/if_equal}}>{{this.name}} ({{t "userDetails.approverLabel"}} {{this.boss.name}} {{this.boss.lastname}})</option>
      {{/each}}
    </select>
    <span id="department_help" class="help-block">{{t "userDetails.departmentHelp"}} <a href="/settings/departments/edit/{{employee.DepartmentId}}">{{t "common.moreDetails"}} <i class="fa fa-angle-double-right" aria-hidden="true"></i></a></span>
  </div>

  <div class="form-group">
      <div class="checkbox">
      <label for="admin_inp">
        <input id="admin_inp" name="admin" type="checkbox" {{# if employee.admin}} checked="checked"{{/if}}>
        {{t "userDetails.isAdmin"}}
      </label>
      </div>
  </div>

  <div class="form-group">
      <div class="checkbox">
      <label for="auto_approve_inp">
        <input id="auto_approve_inp" name="auto_approve" type="checkbox" {{# if employee.auto_approve}} checked="checked"{{/if}} aria-describedby="auto_approve_help">
        {{t "userDetails.autoApprove"}}
      </label>
      </div>
      <span id="auto_approve_help" class="help-block">{{t "userDetails.autoApproveHelp" name=(full_name employee)}}</span>
  </div>

  <div class="form-group">
    <label for="start_date_inp" class="control-label">{{t "userDetails.startedOn"}}</label>
    <div class="input-group employee-date-field">
      <span class="input-group-addon"><i class="fa fa-calendar" aria-hidden="true"></i></span>
      <input class="form-control" id="start_date_inp" type="text" name="start_date" required data-date-autoclose="1" data-provide="datepicker" data-date-format="{{#with logged_user.company }}{{this.get_default_date_format_for_date_picker}}{{/with}}" data-date-week-start="1" value="{{as_date employee.start_date}}" aria-describedby="start_date_help">
    </div>
    <span id="start_date_help" class="help-block">{{t "userDetails.startDateHelp"}}</span>
  </div>

  <div class="form-group">
    <label for="end_date_inp" class="control-label">{{t "userDetails.endedOn"}}</label>
    <div class="input-group employee-date-field">
      <span class="input-group-addon"><i class="fa fa-calendar" aria-hidden="true"></i></span>
      <input class="form-control" id="end_date_inp" type="text" name="end_date" data-date-autoclose="1" data-provide="datepicker" data-date-format="{{#with logged_user.company }}{{this.get_default_date_format_for_date_picker}}{{/with}}" data-date-week-start="1" value="{{as_date employee.end_date}}" aria-describedby="end_date_help">
    </div>
    <span id="end_date_help" class="help-block employee-help-stack"><span>{{t "userDetails.endDateHelp" company=company.name}}</span><span>{{t "userDetails.endDateHelpAccess"}}</span><span>{{t "userDetails.endDateHelpDeactivate"}}</span></span>
  </div>

  <div class="form-group">
    <label for="password_inp" class="control-label">{{t "userDetails.password"}}</label>
    <input class="form-control" id="password_inp" type="password" name="password_one" value="" {{#if company.ldap_auth_enabled}} readonly {{/if}} aria-describedby="password_inp_help">
    <span id="password_inp_help" class="help-block">
      {{# if company.ldap_auth_enabled }}
        <a href="/settings/company/authentication/">{{t "userDetails.ldapLink"}}</a> {{t "userDetails.ldapEnabled"}}
      {{else}}
        {{t "userDetails.passwordUpdate"}}
      {{/ if}}
    </span>
  </div>

  <div class="form-group">
    <label for="confirm_password_inp" class="control-label">{{t "userDetails.confirmPassword"}}</label>
    <input class="form-control" id="confirm_password_inp" type="password" name="password_confirm" value="" {{# if company.ldap_auth_enabled}}readonly{{/if}}>
  </div>

  <div class="form-group">
    <p class="control-label">
      <a href="/audit/email/?user_id={{employee.id}}">{{t "userDetails.emailsSentTo" name=(full_name employee)}}</a>
    </p>
  </div>
<div class="admin-form-actions">
  <a class="btn btn-link" href="/users/">{{t "common.cancel"}}</a>
  <button id="save_changes_btn" type="submit" class="btn btn-success single-click">{{t "common.saveChanges"}}</button>
</div>

</form>
