
{{# each grouped_leaves}}
  <h2>{{this.year}}</h2>
  {{> user_requests leaves=this.leaves no_header=1 logged_user=../logged_user table_label=(t "requests.allAbsences")}}
  <p><em>{{t "requests.deductedFromAllowance"}}:</em> <span>{{ this.total_deduction }}</span></p>
  <div class="content-spacer" aria-hidden="true"></div>
{{/ each}}
