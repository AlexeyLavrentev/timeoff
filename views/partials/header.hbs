<div class="header">

<nav class="navbar navbar-default">
  <div class="container-fluid">
    <!-- Brand and toggle get grouped for better mobile display -->
    <div class="navbar-header">
      <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#bs-example-navbar-collapse-1">
        <span class="sr-only">{{t "nav.toggle"}}</span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
        <span class="icon-bar"></span>
      </button>
      <a class="navbar-brand" href="{{url_to_the_site_root}}">{{t "brand.name"}}</a>
    </div>

    <!-- Collect the nav links, forms, and other content for toggling -->
    <div class="collapse navbar-collapse" id="bs-example-navbar-collapse-1">
      <ul class="nav navbar-nav navbar-left">
        {{# if logged_user }}
          <li><a href="/calendar/">{{t "nav.calendar"}}</a></li>
          {{# unless keep_team_view_hidden }}
            <li><a href="/calendar/teamview/">{{t "nav.teamView"}}</a></li>
          {{/ unless }}
          <li><a href="/time-balance/">{{t "nav.timeBalance"}} <span id="time-balance-nav-badge" class="label label-info hidden"></span></a></li>
          {{# if logged_user.admin }}
            <li class="hidden-xs"><a href="/users/">{{t "nav.employees"}}</a></li>
          {{/if}}
          <li class="navbar-form navbar-left">
            <div class="form-group">
              <button type="button" class="btn btn-info" data-toggle="modal" data-target="#book_leave_modal" id="book_time_off_btn">{{t "nav.newAbsence"}}</button>
            </div>
          </li>
        {{/if}}
      </ul>
      <ul class="nav navbar-nav navbar-right">
        <li class="dropdown" id="theme-menu">
          <a href="#" class="dropdown-toggle nav-icon-link" data-toggle="dropdown" role="button" aria-expanded="false" aria-label="{{t "theme.label"}}" title="{{t "theme.label"}}">
            <span class="fa fa-sun-o theme-icon" aria-hidden="true"></span>
            <span class="sr-only">{{t "theme.label"}}: <span class="theme-label">{{t "theme.light"}}</span></span>
            <span class="caret"></span>
          </a>
          <ul class="dropdown-menu" role="menu">
            <li><a href="#" data-theme-value="light"><span class="fa fa-sun-o nav-menu-icon" aria-hidden="true"></span>{{t "theme.light"}}</a></li>
            <li><a href="#" data-theme-value="dark"><span class="fa fa-moon-o nav-menu-icon" aria-hidden="true"></span>{{t "theme.dark"}}</a></li>
          </ul>
        </li>
        <li class="dropdown hidden-xs">
          <a href="#" class="dropdown-toggle nav-icon-link" data-toggle="dropdown" role="button" aria-expanded="false" aria-label="{{t "language.label"}}" title="{{t "language.label"}}">
            <span class="fa fa-language" aria-hidden="true"></span>
            <span class="sr-only">{{t "language.label"}}: {{#if_equal locale "ru"}}{{t "language.russian"}}{{else}}{{t "language.english"}}{{/if_equal}}</span>
            <span class="caret"></span>
          </a>
          <ul class="dropdown-menu" role="menu">
            <li><a href="/language/en"><span class="fa fa-language nav-menu-icon" aria-hidden="true"></span>{{t "language.english"}}</a></li>
            <li><a href="/language/ru"><span class="fa fa-language nav-menu-icon" aria-hidden="true"></span>{{t "language.russian"}}</a></li>
          </ul>
        </li>
        {{#if logged_user }}
          <li class="dropdown" id="header-notification-dropdown">
            <a href="#" class="dropdown-toggle nav-icon-link" data-toggle="dropdown" role="button" aria-expanded="false" aria-label="{{t "nav.notificationsEmpty"}}" title="{{t "nav.notificationsEmpty"}}">
              <span class="fa fa-bell-o" aria-hidden="true"></span>
              <span class="label label-info notification-badge hidden"></span>
            </a>
            <ul class="dropdown-menu" role="menu">
              <li class="dropdown-header">{{t "nav.notificationsEmpty"}}</li>
            </ul>
          </li>
          {{#if logged_user.admin }}
          <li class="dropdown hidden-xs">
            <a href="#" class="dropdown-toggle nav-icon-link" data-toggle="dropdown" role="button" aria-expanded="false" aria-label="{{t "nav.settings"}}" title="{{t "nav.settings"}}"><span class="fa fa-cog" aria-hidden="true"></span> <span class="caret"></span></a>
            <ul class="dropdown-menu settings-dropdown-menu" role="menu">
              <li><a href="/settings/general/"><span class="fa fa-cog nav-menu-icon" aria-hidden="true"></span>{{t "nav.general"}}</a></li>
              <li role="separator" class="divider"></li>
              <li><a href="/settings/departments/"><span class="fa fa-sitemap nav-menu-icon" aria-hidden="true"></span>{{t "nav.departments"}}</a></li>
              <li><a href="/settings/groups/"><span class="fa fa-users nav-menu-icon" aria-hidden="true"></span>{{t "nav.groups"}}</a></li>
              <li><a href="/settings/bankholidays/"><span class="fa fa-calendar-o nav-menu-icon" aria-hidden="true"></span>{{t "nav.bankHolidays"}}</a></li>
              <li><a href="/settings/company/authentication/"><span class="fa fa-lock nav-menu-icon" aria-hidden="true"></span>{{t "nav.authConfig"}}</a></li>
              <li><a href="/settings/company/integration-api/"><span class="fa fa-plug nav-menu-icon" aria-hidden="true"></span>{{t "nav.apiConfig"}}</a></li>
              <li><a href="/users/import/"><span class="fa fa-upload nav-menu-icon" aria-hidden="true"></span>{{t "nav.importEmployees"}}</a></li>
              <li role="separator" class="divider"></li>
              <li><a href="/audit/email/"><span class="fa fa-envelope-o nav-menu-icon" aria-hidden="true"></span>{{t "nav.emailsAudit"}}</a></li>
              <li><a href="/reports/"><span class="fa fa-line-chart nav-menu-icon" aria-hidden="true"></span>{{t "nav.reports"}}</a></li>
            </ul>
          </li>
          {{/if}}
          <li class="visible-xs-block"><a href="/requests/">{{t "nav.requests"}}</a></li>
          <li class="visible-xs-block"><a href="/logout/">{{t "nav.logout"}}</a></li>
          <li class="dropdown hidden-xs">
            <a id="me_menu" href="#" class="dropdown-toggle nav-icon-link" data-toggle="dropdown" role="button" aria-expanded="false" aria-label="{{t "nav.me"}}" title="{{t "nav.me"}}"><span class="fa fa-user" aria-hidden="true"></span> <span class="caret"></span></a>
            <ul class="dropdown-menu" role="menu">
              <li><a href="/requests/"><span class="fa fa-inbox nav-menu-icon" aria-hidden="true"></span>{{t "nav.requests"}}</a></li>
              <li class="hidden-xs"><a href="/calendar/feeds/"><span class="fa fa-rss nav-menu-icon" aria-hidden="true"></span>{{t "nav.feeds"}}</a></li>
              <li role="separator" class="divider hidden-xs"></li>
              <li><a href="/logout/"><span class="fa fa-sign-out nav-menu-icon" aria-hidden="true"></span>{{t "nav.logout"}}</a></li>
            </ul>
          </li>
        {{else}}
          <li><a href="/login/">{{t "nav.login"}}</a></li>
        {{/if}}
      </ul>
    </div><!-- /.navbar-collapse -->
  </div><!-- /.container-fluid -->
</nav>

{{# if logged_user }}
  {{# if logged_user.company.company_wide_message  }}
    <div class="alert alert-danger" role="alert">{{ logged_user.company.company_wide_message }}</div>
  {{/if}}
{{/if}}

</div>
