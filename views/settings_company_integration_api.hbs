
{{> header }}

<a class="sr-only sr-only-focusable" href="#main-content">{{t "nav.skipToMainContent"}}</a>

<main id="main-content" tabindex="-1">

<h1>{{t "integrationApi.title"}}</h1>

<p class="lead">{{t "integrationApi.subtitle"}}</p>

{{> show_flash_messages }}

<div class="row main-row_header">
  <p class="col-md-12">{{t "common.description"}}</p>
</div>

<div class="row">
  <div class="col-md-8">
    <p>{{t "integrationApi.description" company=company.name}}</p>
    <p>{{# if company.integration_api_enabled }}{{t "integrationApi.toggleDisable"}}{{else}}{{t "integrationApi.toggleEnable"}}{{/if}}</p>
  </div>
</div>

<div class="row main-row_header">
  <p class="col-md-12">{{t "common.configuration"}}</p>
</div>

<div class="row">
  <div class="col-md-9">
    <form class="form-horizontal admin-form-card" action="" method="post">
      <input type="hidden" name="_csrf" value="{{csrf_token}}">
      <div class="form-group">
        <div class="col-md-9 col-md-offset-3">
        <label for="integration_api_enabled" class="control-label">
          <input
            id="integration_api_enabled"
            type="checkbox"
            {{# if company.integration_api_enabled }} checked="checked" {{/if}}
            name="integration_api_enabled"
           />&nbsp;
           {{t "integrationApi.enable"}}
          </label>
        </div>
      </div>
      <hr/>
      <div class="form-group">
        <label for="token" class="col-md-3 control-label">{{t "integrationApi.accessKey"}}</label>
        <div class="col-md-5">
          {{#if accessToken}}
            <input class="form-control" readonly value="{{accessToken}}" aria-describedby="token_help" type="text" id="token-value">
          {{else}}
            <p class="form-control-static" id="token-value-hidden">{{t "integrationApi.tokenHidden"}}</p>
          {{/if}}
        </div>
        <div class="col-md-4">
          <span id="token_help" class="help-block">{{t "integrationApi.tokenHelp" company=company.name}} <span class="danger">{{#if accessToken}}{{t "integrationApi.tokenShownOnce"}}{{else}}{{t "integrationApi.keepSecret"}}{{/if}}</span></span>
        </div>
      </div>
      <div class="admin-form-actions">
        <button type="submit" class="btn btn-default single-click" id="regenerate_token_btn" name="regenerate_token" value=1>{{t "integrationApi.regenerate"}}</button>
        <button type="submit" class="btn btn-success single-click" id="save_settings_btn">{{t "integrationApi.save"}}</button>
      </div>
    </form>
  </div>
</div>

</main>

{{> footer }}
