TIMEOFF_BASE_URL=http://172.16.2.92:3000
TIMEOFF_TOKEN=replace_me

JIRA_BASE_URL=https://jira.example.local
JIRA_AUTH_MODE=basic
JIRA_USER=svc-timeoff-reassign
JIRA_TOKEN=replace_me

# name (Jira Server/Data Center) or accountId (if configured otherwise)
JIRA_ASSIGN_FIELD=name

# Optional additional restriction, example:
# JIRA_EXTRA_JQL=project in (IT,HR) AND issuetype in (Task,Bug)
JIRA_EXTRA_JQL=

# Path to mapping file: TimeOff email -> Jira username
# Optional override map. If empty, worker uses automatic mapping by email.
USER_MAPPING_FILE=./config/user-map.json
AUTO_MAP_BY_EMAIL=true

# Comma-separated leave statuses for TimeOff API
TIMEOFF_LEAVE_STATUSES=Approved

# Optional fixed date for tests (YYYY-MM-DD)
TIMEOFF_DATE=

# Dry run mode: true/false
DRY_RUN=true

# Optional mapping report output
MAPPING_REPORT_FILE=./reports/mapping-report.json
# Optional guardrail. If not_found in mapping summary exceeds this number,
# worker exits with error.
MAPPING_NOT_FOUND_THRESHOLD=

HTTP_TIMEOUT_MS=20000
JIRA_SEARCH_PAGE_SIZE=100
