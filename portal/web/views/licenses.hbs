<h1>Лицензии</h1>
{{#if canIssue}}
<a href="/licenses/new" class="btn">+ Выпустить лицензию</a>
{{/if}}

<form method="GET" action="/licenses" class="filter-form">
  <div class="filter-row">
    <div class="filter-group">
      <label for="customer">Клиент</label>
      <input type="text" id="customer" name="customer" value="{{filters.customer}}" placeholder="Поиск по имени…">
    </div>
    <div class="filter-group">
      <label for="plan">План</label>
      <select id="plan" name="plan">
        <option value="">Все планы</option>
        {{#each plans}}
        <option value="{{this.name}}" {{#if (eq this.name ../filters.plan)}}selected{{/if}}>{{this.name}}</option>
        {{/each}}
      </select>
    </div>
    <div class="filter-group">
      <label for="status">Статус</label>
      <select id="status" name="status">
        <option value="all" {{#if (eq filters.status "all")}}selected{{/if}}>Все</option>
        <option value="active" {{#if (eq filters.status "active")}}selected{{/if}}>Активные</option>
        <option value="expired" {{#if (eq filters.status "expired")}}selected{{/if}}>Истекшие</option>
      </select>
    </div>
    <div class="filter-group">
      <label for="externalCustomerId">Внешний ID</label>
      <input type="text" id="externalCustomerId" name="externalCustomerId" value="{{filters.externalCustomerId}}" placeholder="CRM-123…">
    </div>
    <div class="filter-group">
      <label for="domain">Домен</label>
      <input type="text" id="domain" name="domain" value="{{filters.domain}}" placeholder="example.com">
    </div>
    <div class="filter-group">
      <label for="issueReason">Причина</label>
      <select id="issueReason" name="issueReason">
        <option value="">Все</option>
        <option value="new" {{#if (eq filters.issueReason "new")}}selected{{/if}}>Новая</option>
        <option value="renewal" {{#if (eq filters.issueReason "renewal")}}selected{{/if}}>Продление</option>
        <option value="replacement" {{#if (eq filters.issueReason "replacement")}}selected{{/if}}>Замена</option>
        <option value="correction" {{#if (eq filters.issueReason "correction")}}selected{{/if}}>Коррекция</option>
        <option value="trial" {{#if (eq filters.issueReason "trial")}}selected{{/if}}>Пробная</option>
        <option value="other" {{#if (eq filters.issueReason "other")}}selected{{/if}}>Другое</option>
      </select>
    </div>
    <div class="filter-group">
      <label for="minSeats">Min мест</label>
      <input type="number" id="minSeats" name="minSeats" value="{{filters.minSeats}}" min="1" max="1000000" placeholder="1">
    </div>
    <div class="filter-group">
      <label for="maxSeats">Max мест</label>
      <input type="number" id="maxSeats" name="maxSeats" value="{{filters.maxSeats}}" min="1" max="1000000" placeholder="1000000">
    </div>
    <div class="filter-group">
      <label for="q">Поиск</label>
      <input type="text" id="q" name="q" value="{{filters.q}}" placeholder="Hash, клиент, план…">
    </div>
    <div class="filter-actions">
      <button type="submit" class="btn">Фильтровать</button>
      {{#if hasActiveFilters}}
      <a href="/licenses" class="btn btn-secondary">Сбросить</a>
      {{/if}}
    </div>
  </div>
</form>

{{#if warning}}
<div class="flash flash--warning">{{warning}}</div>
{{/if}}

<table>
  <thead><tr><th>Клиент</th><th>План</th><th>Фичи</th><th>Срок</th><th>Выпущена</th></tr></thead>
  <tbody>
    {{#each licenses}}
    <tr>
      <td><a href="/licenses/{{this.id}}">{{this.customerName}}</a></td>
      <td>{{this.planName}}</td>
      <td class="features-cell">{{this.featuresShort}}</td>
      <td>{{this.expiresAtDisplay}}</td>
      <td>{{this.issuedAtDisplay}}</td>
    </tr>
    {{else}}
    <tr><td colspan="5">Ничего не найдено.</td></tr>
    {{/each}}
  </tbody>
</table>

{{#if pagination}}
<div class="pagination">
  {{#if pagination.hasPrev}}
  <a href="{{{pagination.prevUrl}}}" class="btn btn-secondary">← Назад</a>
  {{/if}}
  <span class="muted">Страница {{pagination.page}}</span>
  {{#if pagination.hasNext}}
  <a href="{{{pagination.nextUrl}}}" class="btn">Далее →</a>
  {{/if}}
</div>
{{/if}}
