<h1>Новый клиент</h1>
{{#if error}}
<div class="flash flash--error">{{error}}</div>
{{/if}}
<form method="POST" action="/customers">
  <input type="hidden" name="_csrf" value="{{csrf}}">
  <div class="form-group">
    <label for="name">Название *</label>
    <input type="text" id="name" name="name" required value="{{values.name}}">
  </div>
  <div class="form-group">
    <label for="contactEmail">Email контакта</label>
    <input type="email" id="contactEmail" name="contactEmail" value="{{values.contactEmail}}">
  </div>
  <div class="form-group">
    <label for="contactName">Имя контакта</label>
    <input type="text" id="contactName" name="contactName" value="{{values.contactName}}">
  </div>
  <div class="form-group">
    <label for="notes">Заметки</label>
    <textarea id="notes" name="notes">{{values.notes}}</textarea>
  </div>
  <button type="submit">Создать</button>
  <a href="/customers" class="btn btn-secondary">Отмена</a>
</form>
