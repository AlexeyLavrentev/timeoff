<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{title}} — LeavePilot Portal</title>
  <link rel="stylesheet" href="/static/style.css">
</head>
<body>
  <header class="header">
    <div class="header-inner">
      <a href="/" class="logo">LeavePilot Portal</a>
      {{#if user}}
      <nav class="nav">
        <a href="/">Dashboard</a>
        <a href="/customers">Клиенты</a>
        <a href="/plans">Планы</a>
        <a href="/licenses">Лицензии</a>
        {{#if (eq user.role "admin")}}
        <a href="/audit">Аудит</a>
        {{/if}}
        <span class="nav-user">{{user.email}} ({{user.role}})</span>
        <form method="POST" action="/logout" class="nav-logout">
          <input type="hidden" name="_csrf" value="{{csrf}}">
          <button type="submit">Выход</button>
        </form>
      </nav>
      {{/if}}
      {{#unless user}}
        {{#if trialEnabled}}
        <nav class="nav nav-public"><a href="/trial">Получить Trial</a></nav>
        {{/if}}
      {{/unless}}
    </div>
  </header>
  <main class="main">
    {{#if flash}}
    <div class="flash flash--{{flash.type}}">{{flash.message}}</div>
    {{/if}}
    {{{body}}}
  </main>
</body>
</html>
