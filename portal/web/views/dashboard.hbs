<h1>Dashboard</h1>
<div class="stats">
  <div class="stat-card">
    <div class="stat-number">{{counts.customers}}</div>
    <div class="stat-label">Клиентов</div>
  </div>
  <div class="stat-card">
    <div class="stat-number">{{counts.plans}}</div>
    <div class="stat-label">Планов</div>
  </div>
  <div class="stat-card">
    <div class="stat-number">{{counts.licenses}}</div>
    <div class="stat-label">Лицензий</div>
  </div>
</div>
{{#if recentLicenses.length}}
<h2>Последние лицензии</h2>
<table>
  <thead><tr><th>Клиент</th><th>План</th><th>Срок</th><th>Выпущена</th></tr></thead>
  <tbody>
    {{#each recentLicenses}}
    <tr>
      <td><a href="/licenses/{{this.id}}">{{this.customerName}}</a></td>
      <td>{{this.planName}}</td>
      <td>{{this.expiresAt}}</td>
      <td>{{this.issuedAt}}</td>
    </tr>
    {{/each}}
  </tbody>
</table>
{{/if}}
