<h1>{{customer.name}}</h1>

<div class="detail-table-wrap">
<table class="detail-table">
  <tr><th>Email</th><td>{{customer.contactEmail}}</td></tr>
  <tr><th>Контакт</th><td>{{customer.contactName}}</td></tr>
  <tr><th>Создан</th><td>{{customer.createdAt}}</td></tr>
  <tr><th>Лицензий</th><td>{{customer.licenseCount}}</td></tr>
  {{#if customer.latestIssuedAt}}
  <tr><th>Последняя лицензия</th><td>{{customer.latestIssuedAt}}</td></tr>
  {{/if}}
</table>
</div>

<div class="actions">
  <a href="/customers" class="btn btn-secondary">← К клиентам</a>
  <a href="/licenses?customer={{customer.filterValue}}" class="btn">Все лицензии</a>
  {{#if canIssue}}
  <a href="/licenses/new" class="btn">+ Выпустить лицензию</a>
  {{/if}}
</div>

<h2>Последние лицензии</h2>

{{#if licenses.length}}
<table>
  <thead>
    <tr>
      <th>План</th>
      <th>Фичи</th>
      <th>Статус</th>
      <th>Срок</th>
      <th>Выпущена</th>
      <th>Кем</th>
      <th>Payload Hash</th>
      <th>License Hash</th>
    </tr>
  </thead>
  <tbody>
    {{#each licenses}}
    <tr>
      <td><a href="/licenses/{{this.id}}">{{this.planName}}</a></td>
      <td class="features-cell">{{this.featuresShort}}</td>
      <td>{{this.statusDisplay}}</td>
      <td>{{this.expiresAtDisplay}}</td>
      <td>{{this.issuedAtDisplay}}</td>
      <td>{{this.actorName}}</td>
      <td><code>{{this.payloadHashShort}}</code></td>
      <td><code>{{this.licenseHashShort}}</code></td>
    </tr>
    {{/each}}
  </tbody>
</table>
{{else}}
<p class="muted">Лицензий для этого клиента пока нет.</p>
{{/if}}
