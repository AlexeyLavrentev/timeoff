<section class="trial-card">
  <h1>LeavePilot Premium на {{trialDays}} дней</h1>
  <p>Все Premium-функции, до {{trialSeats}} активных сотрудников. Банковская карта не требуется.</p>
  {{#if error}}<div class="flash flash--error">{{error}}</div>{{/if}}
  <form method="POST" action="/trial">
    <input type="hidden" name="_csrf" value="{{csrf}}">
    <div class="honeypot" aria-hidden="true">
      <label for="website">Website</label>
      <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
    </div>
    <div class="form-group">
      <label for="organizationName">Организация</label>
      <input type="text" id="organizationName" name="organizationName" maxlength="120" required value="{{form.organizationName}}">
    </div>
    <div class="form-group">
      <label for="contactName">Ваше имя</label>
      <input type="text" id="contactName" name="contactName" maxlength="120" value="{{form.contactName}}">
    </div>
    <div class="form-group">
      <label for="email">Рабочий email</label>
      <input type="email" id="email" name="email" maxlength="254" required value="{{form.email}}">
    </div>
    <button type="submit">Получить Trial</button>
  </form>
  <p class="muted trial-note">Отправим одноразовую ссылку. Один Trial на email.</p>
</section>
